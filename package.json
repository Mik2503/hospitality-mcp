{
  "name": "hospitality-mcp",
  "version": "0.1.0",
  "description": "An unofficial Model Context Protocol (MCP) server that connects hotel PMS platforms (starting with Apaleo) to AI assistants like Claude. Ask and act on your hotel data in natural language.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "apaleo",
    "pms",
    "hotel",
    "hospitality",
    "hoteltech",
    "ai"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "hospitality-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "verify:auth": "tsx src/scripts/verify-auth.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
