# ------------------------------------------------------------------
# hospitality-mcp — example environment configuration
#
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env
#
# NEVER commit your real `.env` file. It is git-ignored on purpose.
# These are placeholders only — no real secrets belong in this file.
# ------------------------------------------------------------------

# --- Which PMS to talk to ---
# "apaleo" (default) talks to a real/sandbox Apaleo account (needs the
#   credentials below).
# "demo" serves BUILT-IN SYNTHETIC sample data — no account, no credentials.
#   Great for trying the server in 30 seconds. It is READ-ONLY and clearly
#   labeled "(SAMPLE DATA)". To switch to your real hotel later, set this back
#   to "apaleo" (or remove it) and fill in the credentials below.
PMS_PROVIDER=apaleo

# --- Apaleo OAuth2 credentials (required only when PMS_PROVIDER=apaleo) ---
# Create a free connected application in the Apaleo dashboard to get these:
#   https://apaleo.dev  ->  Sign up  ->  Connected apps
# (Not needed at all in demo mode.)
APALEO_CLIENT_ID=your_client_id_here
APALEO_CLIENT_SECRET=your_client_secret_here

# --- Write mode (optional) ---
# Writes (create / modify / cancel reservations) are DISABLED by default.
# Set to "true" ONLY if you understand the consequences. When false, the
# write tools are not registered at all and no write scopes are requested.
#
# IMPORTANT: enabling writes makes the server request the `reservations.manage`
# scope. Your Apaleo connected app MUST have that scope granted, otherwise even
# the login (token request) will fail and reads will stop working too. Grant the
# scope in the dashboard first, then set this to true.
APALEO_ENABLE_WRITES=false

# --- Optional: scope queries to a single property by default ---
# If you manage one hotel, set its Apaleo property id (e.g. "BER") so tools
# default to it when no property is specified. Leave blank to require it.
APALEO_DEFAULT_PROPERTY_ID=

# --- Optional: advanced endpoint overrides ---
# Sensible Apaleo production defaults are used when these are unset.
# Only change them if Apaleo updates their endpoints or you use a mock.
# APALEO_TOKEN_URL=https://identity.apaleo.com/connect/token
# APALEO_API_BASE_URL=https://api.apaleo.com

# --- Optional: logging ---
# One of: error | warn | info | debug   (default: info)
LOG_LEVEL=info
